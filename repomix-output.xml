                              <span key={ch} style={{ display: 'inline-flex', alignItems: 'center', gap: '3px', fontSize: '10px', color: meta.color, padding: '1px 6px', borderRadius: '4px', backgroundColor: meta.color + '18', border: `1px solid ${meta.color}33` }}>
