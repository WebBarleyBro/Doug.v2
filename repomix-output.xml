/* ─── Focus ───────────────────────────────────────────────────────────────── */

:focus-visible { outline: 2px solid var(--border-focus); outline-offset: 2px; }

/* ─── Form inputs ─────────────────────────────────────────────────────────── */

input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.5); }

/* ─── Mobile safe area ────────────────────────────────────────────────────── */

.mobile-nav-safe { padding-bottom: env(safe-area-inset-bottom, 0px); }

/* ─── Section divider ─────────────────────────────────────────────────────── */

.section-rule {
  height: 1px;
