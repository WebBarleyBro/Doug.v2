              </div>
            </div>
            {(visitFilter === 'all' ? drVisits : visitFilter === 'wins' ? drWinVisits : visitFilter === 'action' ? drActionVisits : drVisits.filter((v: any) => !ACTION_STATUSES.includes(v.status) && !WIN_STATUSES.includes(v.status))).length === 0 ? (
