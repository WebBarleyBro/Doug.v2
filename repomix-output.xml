            ) : (
              <>
                {/* Summary counts */}
                <div style={{ display: 'flex', gap: '8px', flexWrap: 'wrap', marginBottom: '16px' }}>
                  {Object.entries(REG_STATUS_LABELS).map(([status, label]) => {
